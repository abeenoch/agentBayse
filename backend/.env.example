TAVILY_API_KEY=
SERPAPI_KEY=

# Agent Config
AGENT_AUTO_TRADE=false
AGENT_MAX_POSITION_SIZE=5000
AGENT_SCAN_INTERVAL_SECONDS=900
AGENT_MAX_DAILY_TRADES=20
AGENT_EVENT_PAGE_SIZE=20
AGENT_EVENT_PAGES=2

# DB
DATABASE_URL=sqlite+aiosqlite:///./bayse_agent.db

# Dev
MOCK_MODE=true
